# Copiar este archivo a .env.local (desarrollo) y cargar las mismas
# variables en el dashboard de Vercel para producción. Nunca subir el
# archivo real con secretos al repositorio (.env.local ya está en .gitignore).

# Conexión a la base de datos Neon Postgres
DATABASE_URL=postgresql://usuario:password@host/basededatos?sslmode=require

# Auth.js: clave para firmar los JWT de sesión (generar con: openssl rand -base64 32)
AUTH_SECRET=

# Validación de RUC contra SUNAT vía Decolecta (https://decolecta.com).
# El token se obtiene desde el dashboard de Decolecta (plan gratuito con cuota mensual).
SUNAT_API_URL=https://api.decolecta.com/v1/sunat/ruc
SUNAT_API_TOKEN=

# Mercado Pago (pasarela de pago).
# OJO: el access token de PRODUCCIÓN ("APP_USR-...") hace cobros reales.
# Para desarrollo/demo usen un usuario de prueba de Mercado Pago (access
# token "TEST-..."), y cambien a producción solo cuando de verdad quieran
# cobrar. Si se dejan vacías, el sistema SIMULA el pago (aprobado, salvo con
# un token que empiece con "token_test_fail") para no bloquear la demo.
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# Vercel Blob (almacenamiento de documentos y PDFs)
BLOB_READ_WRITE_TOKEN=

# Resend (envío de correos: recuperación de contraseña, notificaciones)
RESEND_API_KEY=
RESEND_FROM_EMAIL=notificaciones@licencias-trujillo.pe

# URL pública del sitio (usada para generar el QR de la licencia)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
